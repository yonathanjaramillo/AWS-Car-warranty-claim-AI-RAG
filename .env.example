# Copy this to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore

# AWS credentials (use AWS CLI profile or IAM role in prod)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here

# S3 buckets (created by Terraform)
CLAIMS_BUCKET=warranty-claim-ai-claims
POLICIES_BUCKET=warranty-claim-ai-policies

# DynamoDB
DYNAMODB_TABLE=warranty-claim-ai-state

# Bedrock Knowledge Base IDs — fill in after `terraform apply`
KB_ID_FORD=
KB_ID_GM=
KB_ID_TOYOTA=
KB_ID_STELLANTIS=

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
API_KEY=dev-key-change-in-prod
